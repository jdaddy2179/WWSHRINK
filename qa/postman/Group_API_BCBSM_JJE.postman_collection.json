					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const res = pm.response.json();",
									"const data = (res.data && res.data[0]) || res.data || res;",
									"",
									"pm.test(\"Status result is OK\", function () {",
									"    pm.response.to.have.status(\"OK\");",
									"});",
									"",
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response data has 3 nodes\", function () {",
									"    pm.expect(Object.keys(data)).to.have.lengthOf(3);",
									"});",
									"",
									"pm.test(\"Response data node has RecordId, ResultCode and Message sub-node\", function () {",
									"    pm.expect(data).to.have.property(\"RecordId\");",
									"    pm.expect(data).to.have.property(\"ResultCode\");",
									"    pm.expect(data).to.have.property(\"Message\");",
									"});",
									"",
									"pm.test(\"Response data RecordId sub-node's value is 149424\", function () {",
									"    pm.expect(data.RecordId).to.eql(149424);",
									"});",
									"",
									"pm.test(\"Response data node has ResultCode node with the value Succeeded\", function () {",
									"    pm.expect(data.ResultCode).to.eql(\"Succeeded\");",
									"});",
									"",
									"pm.test(\"Response data has Message node with value = TerminationDate has been successfully updated for PlanGroup and PlanCoverage\", function () {",
									"    pm.expect(data.Message).to.eql(\"TerminationDate has been successfully updated for PlanGroup and PlanCoverage\");",
									"});"
								]
							}
						}
					],
