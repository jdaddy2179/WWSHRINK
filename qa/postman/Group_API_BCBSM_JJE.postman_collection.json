				{
					"name": "Same Plan",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const res = pm.response.json();",
									"const data = res.data || res;",
									"",
									"pm.test(\"Status result is OK\", function () {",
									"    pm.response.to.have.status(\"OK\");",
									"});",
									"",
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"function checkNodeNames(obj, names, label) {",
									"    const keys = Object.keys(obj);",
									"    names.forEach(function (name, i) {",
									"        pm.test(\"Response data' node \" + (i + 1) + \" name is: \" + name, function () {",
									"            pm.expect(keys[i]).to.eql(name);",
									"        });",
									"    });",
									"    pm.test(label + \" node has \" + names.length + \" sub-node\", function () {",
									"        pm.expect(keys).to.have.lengthOf(names.length);",
									"    });",
									"}",
									"",
									"// Top-level data node (16 sub-nodes)",
									"checkNodeNames(data, [",
									"    \"PlanEffectiveDate\",",
									"    \"PlanTerminationDate\",",
									"    \"EmployerRenewalDate\",",
									"    \"BptTemplate\",",
									"    \"PlanCoverages\",",
									"    \"MaximumApplies\",",
									"    \"BenefitPeriodMaximums\",",
									"    \"DeductibleApplies\",",
									"    \"BenefitPeriodDeductibles\",",
									"    \"CoinsuranceApplies\",",
									"    \"BenefitPeriodCoinsurances\",",
									"    \"OopMemberMaximumApplies\",",
									"    \"BenefitPeriodOopMemberMaxes\",",
									"    \"WaitingPeriodApplies\",",
									"    \"BenefitPeriodWaitingPeriods\",",
									"    \"Rules\"",
									"], \"Response data\");",
									"",
									"// PlanCoverages node (15 sub-nodes)",
									"const planCoverage = (data.PlanCoverages && data.PlanCoverages[0]) || {};",
									"checkNodeNames(planCoverage, [",
									"    \"MaxDependentAge\",",
									"    \"MaxDependentAgeCalculation\",",
									"    \"AllowAdultDependents\",",
									"    \"AllowDisabledDependents\",",
									"    \"AllowDomesticPartner\",",
									"    \"AllowStudents\",",
									"    \"MaxStudentAge\",",
									"    \"MaxStudentAgeCalculation\",",
									"    \"WaitingPeriodApplies\",",
									"    \"OrthoCoverage\",",
									"    \"AllowNonParPayment\",",
									"    \"WaitingPeriodNumOfDays\",",
									"    \"NonParMemberEffectiveDate\",",
									"    \"PlanCoverageEffectiveDate\",",
									"    \"PlanCoverageTerminationDate\"",
									"], \"PlanCoverages\");",
									"",
									"// Rules node (11 sub-nodes)",
									"const rules = (data.Rules && data.Rules[0]) || {};",
									"checkNodeNames(rules, [",
									"    \"EffectiveDate\",",
									"    \"TerminationDate\",",
									"    \"ProcedureCode\",",
									"    \"ProcedureClassRelationApplies\",",
									"    \"ProcedureClassRelation\",",
									"    \"ProcedureRuleApplies\",",
									"    \"ProcedureRules\",",
									"    \"ProcedurePaymentApplies\",",
									"    \"ProcedurePayments\",",
									"    \"BenefitCrossCheckApplies\",",
									"    \"BenefitCrossChecks\"",
									"], \"Rules\");",
									"",
									"// BenefitPeriodMaximums node (16 sub-nodes)",
									"const bpm = (data.BenefitPeriodMaximums && data.BenefitPeriodMaximums[0]) || {};",
									"checkNodeNames(bpm, [",
									"    \"EffectiveDate\",",
									"    \"TerminationDate\",",
									"    \"MaximumRules\",",
									"    \"StartDateOption\",",
									"    \"PlanYearBegins\",",
									"    \"AllowCarryForward\",",
									"    \"Relationship\",",
									"    \"CarryForwardNumberOfMonths\",",
									"    \"MinimumAge\",",
									"    \"MinimumYearsMonths\",",
									"    \"MinimumAgeCalculation\",",
									"    \"MaximumAge\",",
									"    \"MaximumYearsMonths\",",
									"    \"MaximumAgeCalculation\",",
									"    \"RollOverMaximumApplies\",",
									"    \"RollOverMaximum\"",
									"], \"BenefitPeriodMaximums\");",
									"",
									"// BenefitPeriodMaximums.MaximumRules node (7 sub-nodes)",
									"const maxRules = (bpm.MaximumRules && bpm.MaximumRules[0]) || {};",
									"checkNodeNames(maxRules, [",
									"    \"MaximumAmount\",",
									"    \"AppliesToIndFam\",",
									"    \"MaximumClasses\",",
									"    \"AppliesToNetworkParticipation\",",
									"    \"BenefitPeriodSetting\",",
									"    \"NumberOfPeriodsForBenefitSettings\",",
									"    \"GroupForOverride\"",
									"], \"BenefitPeriodMaximums.MaximumRules\");"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/Benefits/Plan/BusinessUnit/BCBSM/ExternalId/{{extSubGroupId}}/PlanName/{{modifiedPlanName}}/AllDetails",
