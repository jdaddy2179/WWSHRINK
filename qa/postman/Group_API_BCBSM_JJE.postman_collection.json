			"item": [
				{
					"name": "Add Plan",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const res = pm.response.json();",
									"const data = res.data || res;",
									"",
									"pm.test(\"Status result is OK\", function () {",
									"    pm.response.to.have.status(\"OK\");",
									"});",
									"",
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"// The Add Plan request creates a Client, a Group and a Plan -> 3 result rows.",
									"const expected = [",
									"    { resultCode: \"Succeeded\", messageStartsWith: \"ClientId:\" },",
									"    { resultCode: \"Succeeded\", messageStartsWith: \"GroupId:\" },",
									"    { resultCode: \"Succeeded\", messageStartsWith: \"PlanId:\" }",
									"];",
									"",
									"expected.forEach(function (exp, i) {",
									"    const n = i + 1;",
									"    const row = data[i];",
									"",
									"    pm.test(\"Response \" + n + \" data node has 3 sub-nodes\", function () {",
									"        pm.expect(Object.keys(row)).to.have.lengthOf(3);",
									"    });",
									"",
									"    pm.test(\"Response \" + n + \" data node has RecordId, ResultCode and Message sub-node\", function () {",
									"        pm.expect(row).to.have.property(\"RecordId\");",
									"        pm.expect(row).to.have.property(\"ResultCode\");",
									"        pm.expect(row).to.have.property(\"Message\");",
									"    });",
									"",
									"    pm.test(\"Response \" + n + \" data RecordId sub-node's value is 1\", function () {",
									"        pm.expect(row.RecordId).to.eql(1);",
									"    });",
									"",
									"    pm.test(\"Response \" + n + \" data node has ResultCode properties with the value \" + exp.resultCode, function () {",
									"        pm.expect(row.ResultCode).to.eql(exp.resultCode);",
									"    });",
									"",
									"    pm.test(\"Response \" + n + \" data has Message node with value starting \" + exp.messageStartsWith, function () {",
									"        pm.expect(row.Message).to.be.a(\"string\").and.to.satisfy(function (m) {",
									"            return m.indexOf(exp.messageStartsWith) === 0;",
									"        });",
									"    });",
									"});"
								]
							}
						}
					],
